rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    function isIncomingOwner() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || (isSignedIn() && request.auth.token.email == 'igor.cidade@hotmail.com');
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (isSignedIn() && request.auth.token.email == 'igor.cidade@hotmail.com');
      allow delete: if (isSignedIn() && request.auth.token.email == 'igor.cidade@hotmail.com');
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /services/{id} {
      allow read: if isDataOwner();
      allow create: if isIncomingOwner();
      allow update, delete: if isDataOwner() && isIncomingOwner();
    }

    match /products/{id} {
      allow read: if isDataOwner();
      allow create: if isIncomingOwner();
      allow update, delete: if isDataOwner() && isIncomingOwner();
    }

    match /clients/{id} {
      allow read: if isDataOwner();
      allow create: if isIncomingOwner();
      allow update, delete: if isDataOwner() && isIncomingOwner();
    }

    match /sales/{id} {
      allow read: if isDataOwner();
      allow create: if isIncomingOwner();
      allow update, delete: if isDataOwner() && isIncomingOwner();
    }

    match /expenses/{id} {
      allow read: if isDataOwner();
      allow create: if isIncomingOwner();
      allow update, delete: if isDataOwner() && isIncomingOwner();
    }
  }
}
