rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    function isIncomingOwner() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             (request.auth.token.email == 'igor.cidade@hotmail.com' || request.auth.token.email == 'igrcidade@gmail.com');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /leads/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /services/{id} {
      allow read: if isDataOwner() || isAdmin();
      allow create: if isIncomingOwner();
      allow update: if (isDataOwner() && isIncomingOwner()) || isAdmin();
      allow delete: if isDataOwner() || isAdmin();
    }

    match /products/{id} {
      allow read: if isDataOwner() || isAdmin();
      allow create: if isIncomingOwner();
      allow update: if (isDataOwner() && isIncomingOwner()) || isAdmin();
      allow delete: if isDataOwner() || isAdmin();
    }

    match /clients/{id} {
      allow read: if isDataOwner() || isAdmin();
      allow create: if isIncomingOwner();
      allow update: if (isDataOwner() && isIncomingOwner()) || isAdmin();
      allow delete: if isDataOwner() || isAdmin();
    }

    match /barbers/{id} {
      allow read: if isDataOwner() || isAdmin();
      allow create: if isIncomingOwner();
      allow update, delete: if isDataOwner() || isAdmin();
    }

    match /sales/{id} {
      allow read: if isDataOwner() || isAdmin();
      allow create: if isIncomingOwner();
      allow update: if (isDataOwner() && isIncomingOwner()) || isAdmin();
      allow delete: if isDataOwner() || isAdmin();
    }

    match /expenses/{id} {
      allow read: if isDataOwner() || isAdmin();
      allow create: if isIncomingOwner();
      allow update: if (isDataOwner() && isIncomingOwner()) || isAdmin();
      allow delete: if isDataOwner() || isAdmin();
    }
  }
}
